---
import { reader } from '../lib/reader';
import { type Locale, t, strings, localePath, pathWithoutLocale, hasLocaleEquivalent } from '../lib/i18n';

const locale: Locale = (Astro.props.locale as Locale) ?? 'en';
const s = strings(locale);

const contact = await reader.singletons.contactInfo.read();
const site = await reader.singletons.site.read();
const phone = contact?.phone ?? '(579) 366-4118';
const phoneHref = 'tel:' + phone.replace(/[^0-9+]/g, '');
const address = t(contact, 'address', locale, '2229 Hawarden, Montréal, Québec');
const hours = t(contact, 'hours', locale, 'Mon–Sun · 8:00 AM – 9:00 PM');
const facebook = contact?.facebook;
const instagram = contact?.instagram;
const logo = site?.logo;

const nav = [
  { href: '/', label: s.nav.home },
  { href: '/promotions', label: s.nav.promotions },
  { href: '/services', label: s.nav.services },
  { href: '/reviews', label: s.nav.reviews },
  { href: '/about', label: s.nav.about },
  { href: '/contact', label: s.nav.contact },
];

const path = Astro.url.pathname;
const cleanPath = pathWithoutLocale(path);
function isCurrent(href: string) {
  const a = cleanPath.replace(/\/$/, '') || '/';
  const b = href.replace(/\/$/, '') || '/';
  return a === b;
}

const otherLocale: Locale = locale === 'en' ? 'fr' : 'en';
// If the current path has no equivalent in the other locale (e.g. /blog has
// no FR version), fall back to the other locale's home page rather than
// produce a 404.
const otherLocaleHref = hasLocaleEquivalent(cleanPath, otherLocale)
  ? localePath(cleanPath, otherLocale)
  : localePath('/', otherLocale);
---
<header class="site-header border-b border-stone-200 bg-stone-50/95 backdrop-blur sticky top-0 z-[110] transition-shadow duration-300">
  <!-- Top info strip — collapses on scroll to give pages more breathing room.
       Hidden via max-height/opacity transition rather than display:none so
       the collapse animates smoothly. -->
  <div class="site-header__strip bg-stone-100 text-stone-600 text-xs overflow-hidden transition-all duration-300 ease-out">
    <div class="max-w-6xl mx-auto px-6 py-2 flex flex-wrap gap-x-6 gap-y-1 justify-between">
      <div class="flex flex-wrap gap-x-6">
        <span>{hours}</span>
        <a href={phoneHref} class="hover:text-coral-500 transition">{phone}</a>
        <span class="hidden sm:inline">{address}</span>
      </div>
      <div class="flex gap-3 items-center">
        {facebook && (
          <a href={facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-coral-500 transition">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
              <path d="M13.5 21v-7.5h2.55l.38-2.96H13.5V8.66c0-.86.24-1.45 1.47-1.45h1.57V4.56c-.27-.04-1.2-.12-2.28-.12-2.26 0-3.81 1.38-3.81 3.92v2.18H7.9v2.96h2.55V21h3.05Z"/>
            </svg>
          </a>
        )}
        {instagram && (
          <a href={instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-coral-500 transition">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"/>
              <circle cx="12" cy="12" r="3.7"/>
              <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div class="site-header__main max-w-6xl mx-auto px-6 py-4 flex items-center justify-between gap-6 transition-all duration-300 ease-out">
    <a href={localePath('/', locale)} class="flex items-center gap-2 group">
      {logo ? (
        <img src={logo} alt="Spring Massage Therapy" class="site-header__logo h-14 md:h-16 w-auto transition-all duration-300 ease-out" />
      ) : (
        <>
          <span class="text-2xl text-moss-400 group-hover:text-moss-500 transition">🌿</span>
          <span class="font-serif text-lg tracking-wide leading-tight">
            <span class="block text-stone-700">Spring Massage</span>
            <span class="block text-stone-500 text-sm">Therapy</span>
          </span>
        </>
      )}
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm tracking-wide uppercase">
      {nav.map(item => (
        <a
          href={localePath(item.href, locale)}
          class:list={[
            'transition pb-1 border-b-2',
            isCurrent(item.href)
              ? 'border-coral-400 text-stone-700'
              : 'border-transparent text-stone-500 hover:text-stone-700 hover:border-stone-300',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden sm:flex items-center gap-3">
      <!-- Language toggle -->
      <a
        href={otherLocaleHref}
        class="text-stone-500 hover:text-coral-500 transition tracking-wider uppercase text-xs"
        aria-label={locale === 'en' ? 'Voir en français' : 'View in English'}
      >
        <span class:list={[locale === 'en' ? 'text-stone-700 font-medium' : '']}>EN</span>
        <span class="mx-1 text-stone-300">|</span>
        <span class:list={[locale === 'fr' ? 'text-stone-700 font-medium' : '']}>FR</span>
      </a>

      <a
        href={localePath('/book', locale)}
        class="inline-flex bg-coral-400 hover:bg-coral-500 text-white text-sm tracking-wider uppercase px-5 py-2.5 rounded-full transition"
      >
        {s.bookNow}
      </a>
    </div>

    <!-- Mobile menu trigger — animated SVG: three lines morph into an X.
         The aria-label is updated dynamically by the menu script below
         so screen readers hear "Open menu" / "Close menu" appropriately. -->
    <button
      type="button"
      id="mobile-menu-trigger"
      class="md:hidden text-stone-700 w-10 h-10 leading-none flex items-center justify-center"
      aria-label={locale === 'fr' ? 'Ouvrir le menu' : 'Open menu'}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        id="mobile-menu-icon"
        viewBox="0 0 24 24"
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line class="menu-line menu-line-top" x1="4" y1="7" x2="20" y2="7" />
        <line class="menu-line menu-line-mid" x1="4" y1="12" x2="20" y2="12" />
        <line class="menu-line menu-line-btm" x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
  </div>
</header>

<!-- Mobile menu drop-down — sibling of <header> so position:fixed escapes the
     header's sticky/backdrop-blur stacking context. Drops down from the
     top, full-width. The backdrop covers the rest of the screen below it.
     `pointer-events-none` and `invisible` make it untouchable when closed. -->
<div
  id="mobile-menu"
  class="md:hidden fixed inset-0 z-[100] invisible pointer-events-none"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div
    id="mobile-menu-backdrop"
    class="absolute inset-0 bg-stone-700/60 backdrop-blur-sm opacity-0 transition-opacity duration-300 ease-out"
  ></div>

  <!-- Panel — drops from the top, full-width -->
  <div
    id="mobile-menu-panel"
    class="absolute left-0 right-0 top-0 bg-stone-50 shadow-xl flex flex-col max-h-[90vh] overflow-hidden -translate-y-full transition-transform duration-300 ease-out"
  >
    <nav class="overflow-y-auto px-6 py-6 flex flex-col gap-1">
      {nav.map(item => (
        <a
          href={localePath(item.href, locale)}
          class:list={[
            'py-3 px-2 text-base tracking-wide transition border-l-2',
            isCurrent(item.href)
              ? 'border-coral-400 text-stone-700 font-medium'
              : 'border-transparent text-stone-600 hover:text-stone-700 hover:border-stone-300',
          ]}
        >
          {item.label}
        </a>
      ))}

      <div class="border-t border-stone-200 mt-6 pt-6 space-y-3">
        <a
          href={localePath('/book', locale)}
          class="block bg-coral-400 hover:bg-coral-500 text-white text-center text-sm tracking-wider uppercase px-5 py-3 rounded-full transition"
        >
          {s.bookNow}
        </a>
        <a
          href={otherLocaleHref}
          class="block text-center text-stone-500 hover:text-coral-500 transition tracking-wider uppercase text-xs py-2"
          aria-label={locale === 'en' ? 'Voir en français' : 'View in English'}
        >
          <span class:list={[locale === 'en' ? 'text-stone-700 font-medium' : '']}>EN</span>
          <span class="mx-1 text-stone-300">|</span>
          <span class:list={[locale === 'fr' ? 'text-stone-700 font-medium' : '']}>FR</span>
        </a>
      </div>
    </nav>

    <div class="border-t border-stone-200 px-6 py-4 text-xs text-stone-500 space-y-1 shrink-0">
      <a href={phoneHref} class="block hover:text-coral-500 transition">{phone}</a>
      <p>{address}</p>
      <p>{hours}</p>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const trigger = document.getElementById('mobile-menu-trigger');
    const menu = document.getElementById('mobile-menu');
    const panel = document.getElementById('mobile-menu-panel');
    const backdrop = document.getElementById('mobile-menu-backdrop');
    const icon = document.getElementById('mobile-menu-icon');
    if (!trigger || !menu || !panel || !backdrop) return;

    const isFr = document.documentElement.lang === 'fr';
    const labelOpen = isFr ? 'Ouvrir le menu' : 'Open menu';
    const labelClose = isFr ? 'Fermer le menu' : 'Close menu';

    let closeTimer;

    function openMenu() {
      clearTimeout(closeTimer);
      // Position the panel directly below the (sticky) header so it doesn't
      // slide in behind it. Read the header height fresh each open in case
      // the viewport / content has changed.
      const header = document.querySelector('header');
      const headerH = header ? header.getBoundingClientRect().height : 0;
      panel.style.top = headerH + 'px';

      menu.classList.remove('invisible', 'pointer-events-none');
      menu.setAttribute('aria-hidden', 'false');
      trigger.setAttribute('aria-expanded', 'true');
      trigger.setAttribute('aria-label', labelClose);
      icon?.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        backdrop.classList.remove('opacity-0');
        panel.classList.remove('-translate-y-full');
      });
    }

    function closeMenu() {
      backdrop.classList.add('opacity-0');
      panel.classList.add('-translate-y-full');
      menu.setAttribute('aria-hidden', 'true');
      trigger.setAttribute('aria-expanded', 'false');
      trigger.setAttribute('aria-label', labelOpen);
      icon?.classList.remove('is-open');
      document.body.style.overflow = '';
      closeTimer = setTimeout(() => {
        menu.classList.add('invisible', 'pointer-events-none');
      }, 300);
    }

    function isOpen() {
      return menu.getAttribute('aria-hidden') === 'false';
    }

    trigger.addEventListener('click', () => {
      if (isOpen()) closeMenu();
      else openMenu();
    });
    backdrop.addEventListener('click', closeMenu);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) closeMenu();
    });
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
  })();
</script>

<style>
  /* Compact-on-scroll header.
   *
   * Default state: full info strip + roomy main nav (py-4 + h-14/h-16 logo).
   * Scrolled state (`data-scrolled` set on <header>): info strip collapses,
   * main row tightens to ~py-2, logo shrinks. Returns reading space without
   * the user losing the nav.
   *
   * Implemented via a single attribute toggle so the transition runs both
   * directions (collapse on scroll-down, expand on scroll-back-to-top).
   */
  .site-header[data-scrolled] {
    box-shadow: 0 2px 8px -4px rgba(46, 42, 34, 0.12);
  }
  .site-header[data-scrolled] .site-header__strip {
    max-height: 0;
    opacity: 0;
    /* Padding stays inside .site-header__strip's inner div, but the parent
     * collapsing to max-height: 0 hides it visually anyway. */
  }
  .site-header[data-scrolled] .site-header__main {
    padding-top: 0.5rem;     /* py-2 — was py-4 */
    padding-bottom: 0.5rem;
  }
  .site-header[data-scrolled] .site-header__logo {
    height: 2.25rem;          /* h-9 — was h-14 */
  }
  @media (min-width: 768px) {
    .site-header[data-scrolled] .site-header__logo {
      height: 2.5rem;         /* md:h-10 — was md:h-16 */
    }
  }

  /* Pre-scroll: give the strip an explicit max-height so the transition
   * has a value to animate from on the first scroll. 5rem comfortably
   * covers the strip's ~32px content height across breakpoints. */
  .site-header__strip {
    max-height: 5rem;
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .site-header__strip,
    .site-header__main,
    .site-header__logo {
      transition: none !important;
    }
  }
</style>

<script is:inline>
  // Compact header on scroll.
  // Toggle a `data-scrolled` attribute on <header> once the user has
  // scrolled past the threshold. The 80px threshold is enough to be
  // comfortably out of any hero eyebrow line but small enough that the
  // collapse happens early — premium sites do this almost immediately.
  (function () {
    const header = document.querySelector('.site-header');
    if (!header) return;
    const THRESHOLD = 80;
    let scheduled = false;

    function update() {
      scheduled = false;
      if (window.scrollY > THRESHOLD) {
        header.setAttribute('data-scrolled', '');
      } else {
        header.removeAttribute('data-scrolled');
      }
    }

    window.addEventListener('scroll', () => {
      if (!scheduled) {
        scheduled = true;
        requestAnimationFrame(update);
      }
    }, { passive: true });

    // Run once on load in case the page restored mid-scroll (back nav).
    update();
  })();
</script>
