---
import BaseLayout from '../../layouts/BaseLayout.astro';

const postFiles = import.meta.glob<{
  frontmatter: { title: string; description: string; publishedAt: string };
}>('../../content/blog/*.md', { eager: true });

const sorted = Object.entries(postFiles)
  .map(([file, mod]) => ({
    slug: file.split('/').pop()?.replace('.md', '') ?? '',
    title: mod.frontmatter.title,
    description: mod.frontmatter.description,
    publishedAt: mod.frontmatter.publishedAt,
  }))
  .sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());
---
<BaseLayout
  title="Massage Tips & Guides | Spring Massage Therapy Montréal"
  description="Practical guides on massage therapy — what to expect, how to prepare, and how to get the most out of your sessions. From Spring Massage Therapy in Montréal."
>
  <section class="max-w-2xl mx-auto px-6 py-20">
    <header class="mb-12">
      <p class="font-script text-coral-400 text-2xl mb-2">From the studio</p>
      <h1 class="font-serif text-4xl md:text-5xl text-stone-800 mb-4">Blog</h1>
      <div class="w-16 h-px bg-coral-300"></div>
    </header>

    <ul class="divide-y divide-stone-200">
      {sorted.map((post) => {
        const date = new Date(post.publishedAt).toLocaleDateString('en-CA', {
          year: 'numeric', month: 'long', day: 'numeric',
        });
        const iso = new Date(post.publishedAt).toISOString().split('T')[0];
        return (
          <li class="py-8">
            <time datetime={iso} class="text-xs tracking-widest uppercase text-stone-400">{date}</time>
            <h2 class="font-serif text-2xl text-stone-800 mt-2 mb-3">
              <a href={`/blog/${post.slug}`} class="hover:text-coral-500 transition">{post.title}</a>
            </h2>
            <p class="text-stone-500 leading-relaxed mb-4">{post.description}</p>
            <a href={`/blog/${post.slug}`} class="text-sm text-coral-500 hover:underline tracking-wide">
              Read more →
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>
