---
import BaseLayout from '../layouts/BaseLayout.astro';
import { reader } from '../lib/reader';
import { type Locale, t, hasFr, strings, localePath } from '../lib/i18n';

export interface Props { locale: Locale; }
const { locale } = Astro.props;
const s = strings(locale);

const about = await reader.singletons.about.read();
const portrait = about?.zarahPortrait;
const portraitAlt = (((about as any)?.zarahPortraitAlt ?? '') as string).trim()
  || 'Zarah Bellamy, massage therapist at Spring Massage Therapy';
const studio1 = about?.studioImage1;
const studio1Alt = (((about as any)?.studioImage1Alt ?? '') as string).trim()
  || 'Spring Massage Therapy studio interior';
const studio2 = about?.studioImage2;
const studio2Alt = (((about as any)?.studioImage2Alt ?? '') as string).trim()
  || 'Spring Massage Therapy studio courtyard';

// Modern multi-photo gallery. The two visible frames in the layout below
// each cycle through these photos with a slow crossfade. If only 2 are
// uploaded, the layout stays static (current behaviour). If the array
// is empty, fall back to the legacy studioImage1/studioImage2 fields so
// existing content keeps working.
const studioImagesRaw = (about as any)?.studioImages as Array<{ image?: string | null; alt?: string | null } | null | undefined> | undefined;
const studioPhotos = (studioImagesRaw ?? [])
  .map((entry) => {
    if (!entry) return null;
    const src = (entry.image ?? '').trim();
    if (!src) return null;
    const alt = (entry.alt ?? '').trim() || 'Spring Massage Therapy studio';
    return { src, alt };
  })
  .filter((p): p is { src: string; alt: string } => !!p);

const legacyPhotos = [
  studio1 ? { src: studio1, alt: studio1Alt } : null,
  studio2 ? { src: studio2, alt: studio2Alt } : null,
].filter((p): p is { src: string; alt: string } => !!p);

const galleryPhotos = studioPhotos.length >= 2 ? studioPhotos : legacyPhotos;
const galleryRotates = galleryPhotos.length >= 3;
// Slides for each of the two visible frames. Frame A takes the even
// indices (0, 2, 4...), Frame B the odd indices (1, 3, 5...) so the
// two frames don't fade in lockstep and their initial photos differ.
// With 3 photos: A has [0,2], B has [1] (B stays static, A rotates).
// With 4 photos: A has [0,2], B has [1,3] (both rotate).
const frameASlides = galleryPhotos.filter((_, i) => i % 2 === 0);
const frameBSlides = galleryPhotos.filter((_, i) => i % 2 === 1);
const galleryIntervalMs = 5500;
const galleryFadeMs = 1400;

const mapAddress = about?.mapAddress ?? '2229 Hawarden, Montreal, QC';
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(mapAddress)}&output=embed`;

// Credentials line under the bio. Each part is optional; only populated
// pieces render. Joined by a thin middot.
const yearsExperience = (about as any)?.yearsExperience;
const associationMembership = ((about as any)?.associationMembership ?? '').trim();
const languagesSpoken = ((about as any)?.languagesSpoken ?? '').trim();
const insuranceReceipts = (about as any)?.insuranceReceiptsAvailable !== false;
const credentials: string[] = [];
if (typeof yearsExperience === 'number' && yearsExperience > 0) {
  credentials.push(locale === 'fr' ? `${yearsExperience}+ ans d'expérience` : `${yearsExperience}+ years of practice`);
}
if (associationMembership) credentials.push(associationMembership);
if (languagesSpoken) credentials.push(languagesSpoken);
if (insuranceReceipts) {
  credentials.push(locale === 'fr' ? 'Reçus pour assurances' : 'Receipts for insurance reimbursement');
}

const zarahBio = t(about, 'zarahBio', locale, '');
const studioBody = t(about, 'studioBody', locale, '');
const showFrFallbackNotice = locale === 'fr' && (
  !hasFr(about, 'zarahBio') || !hasFr(about, 'studioBody')
);

const titleStr = locale === 'fr'
  ? 'À propos de Zarah & du studio — Spring Massage Therapy'
  : 'About Zarah Bellamy & The Studio — Spring Massage Therapy Montréal';
const descStr = locale === 'fr'
  ? 'La massothérapeute Zarah Bellamy accueille chaque client·e avec compassion et attention. Située dans un manoir Tudor patrimonial au 2229 Hawarden, Montréal — un trésor caché au cœur de la ville.'
  : 'Massage therapist Zarah Bellamy welcomes every client with compassion and care. Located in a heritage Tudor manor at 2229 Hawarden, Montréal — a hidden gem in the heart of the city.';
---
<BaseLayout locale={locale} title={titleStr} description={descStr}>
  <!-- About Zarah -->
  <section class="max-w-5xl mx-auto px-6 py-20 grid md:grid-cols-[1fr_1.4fr] gap-12 items-start">
    <div data-reveal class="aspect-[3/4] bg-stone-200 rounded-sm overflow-hidden flex items-center justify-center text-stone-400 italic order-2 md:order-1">
      {portrait ? (
        <img src={portrait} alt={portraitAlt} class="w-full h-full object-cover" loading="lazy" decoding="async" />
      ) : (
        <span>Portrait</span>
      )}
    </div>
    <div data-reveal style="--reveal-delay: 140ms" class="order-1 md:order-2">
      <p class="font-script text-coral-400 text-2xl mb-2">{s.aboutZarah}</p>
      <h1 class="font-serif text-4xl md:text-5xl mb-2">Zarah Bellamy</h1>
      <p class="text-stone-500 tracking-widest uppercase text-sm mb-6">{s.massageTherapist}</p>
      {showFrFallbackNotice && (
        <p class="text-xs text-stone-500 italic mb-4">{s.translationComingSoon}</p>
      )}
      <div class="space-y-4 text-stone-600 leading-relaxed whitespace-pre-line">
        {zarahBio}
      </div>
      {credentials.length > 0 && (
        <div class="mt-6 pt-6 border-t border-stone-200 text-xs tracking-widest uppercase text-stone-500 flex flex-wrap gap-x-6 gap-y-2">
          {credentials.map((fact, i) => (
            <Fragment>
              {i > 0 && <span class="text-stone-300" aria-hidden="true">·</span>}
              <span>{fact}</span>
            </Fragment>
          ))}
        </div>
      )}
      <p class="italic text-stone-500 mt-6">{s.finalNote}</p>
    </div>
  </section>

  <!-- About the Studio -->
  <section class="bg-stone-100 py-20">
    <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
      <div data-reveal>
        <p class="font-script text-coral-400 text-2xl mb-2">{s.aPeacefulRetreat}</p>
        <h2 class="font-serif text-3xl md:text-4xl mb-6">{s.aboutTheStudio}</h2>
        <div class="space-y-4 text-stone-600 leading-relaxed whitespace-pre-line">
          {studioBody}
        </div>
        <p class="italic text-stone-500 mt-6">{s.hiddenGem}</p>
      </div>
      <div class="grid grid-cols-2 gap-3">
        {/*
          Two stacked frames. Each frame either holds a single static image
          (when only 2 photos are uploaded — legacy behaviour) or a stack
          of imgs that crossfade in sequence (when 3+ photos are uploaded).
          The crossfade is driven by a small inline script at the bottom
          of this section. The two frames offset their first photo so
          they don't visually fade in lockstep.
        */}
        <div
          data-reveal
          style="--reveal-delay: 140ms"
          class="studio-frame relative aspect-[3/4] bg-stone-200 overflow-hidden flex items-center justify-center text-stone-400 italic text-sm"
          data-studio-frame={galleryRotates && frameASlides.length > 1 ? 'a' : null}
          data-interval={galleryIntervalMs}
          data-fade={galleryFadeMs}
        >
          {frameASlides.length > 0 ? (
            frameASlides.map((p, i) => (
              <img
                src={p.src}
                alt={p.alt}
                class:list={[
                  'studio-slide absolute inset-0 w-full h-full object-cover transition-opacity ease-in-out',
                  i === 0 ? 'opacity-100' : 'opacity-0',
                ]}
                style={`transition-duration: ${galleryFadeMs}ms`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            ))
          ) : (
            <span>Studio</span>
          )}
        </div>
        <div
          data-reveal
          style="--reveal-delay: 280ms"
          class="studio-frame relative aspect-[3/4] bg-stone-200 mt-8 overflow-hidden flex items-center justify-center text-stone-400 italic text-sm"
          data-studio-frame={galleryRotates && frameBSlides.length > 1 ? 'b' : null}
          data-interval={galleryIntervalMs}
          data-fade={galleryFadeMs}
        >
          {frameBSlides.length > 0 ? (
            frameBSlides.map((p, i) => (
              <img
                src={p.src}
                alt={p.alt}
                class:list={[
                  'studio-slide absolute inset-0 w-full h-full object-cover transition-opacity ease-in-out',
                  i === 0 ? 'opacity-100' : 'opacity-0',
                ]}
                style={`transition-duration: ${galleryFadeMs}ms`}
                loading="lazy"
                decoding="async"
              />
            ))
          ) : (
            <span>Courtyard</span>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Find Us / Map -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="text-center mb-10">
      <p class="font-script text-coral-400 text-2xl mb-2">{s.findUs}</p>
      <h2 class="font-serif text-3xl md:text-4xl">{mapAddress}</h2>
      <p class="text-stone-500 mt-2">{s.welcome} / {s.welcomeFr}</p>
    </div>
    <div class="rounded-sm overflow-hidden border border-stone-200 aspect-[16/9]">
      <iframe
        src={mapSrc}
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Spring Massage Therapy location"
      ></iframe>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-stone-700 text-stone-50">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="font-script text-coral-200 text-2xl mb-2">{s.youOweYourself}</p>
      <h2 class="font-serif text-3xl md:text-5xl mb-8 text-stone-50">{s.comeAndUnwind}</h2>
      <a href={localePath('/book', locale)} class="bg-coral-400 hover:bg-coral-500 text-white tracking-wider uppercase text-sm px-10 py-4 rounded-full transition inline-block">
        {s.makeAppointment}
      </a>
    </div>
  </section>

  {/*
    Studio gallery crossfade.

    Each frame with `data-studio-frame` set has 2+ photos that should
    rotate. Tick on the interval set in `data-interval`; the photos
    themselves carry a CSS transition-duration matching `data-fade` so
    setting opacity classes here is enough — no JS animation.

    Frame "a" and frame "b" each tick at the same interval, but frame
    b is offset by half the interval at start so they don't crossfade
    in lockstep. Result feels like two slow, lazy slideshows breathing
    independently.

    `prefers-reduced-motion` users see only the first photo, never
    triggered (no setInterval).
  */}
  <script is:inline>
    (function () {
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const frames = document.querySelectorAll('[data-studio-frame]');
      frames.forEach((frame) => {
        const slides = frame.querySelectorAll('.studio-slide');
        if (slides.length < 2) return;
        const interval = Math.max(2000, Number(frame.getAttribute('data-interval')) || 5500);
        const which = frame.getAttribute('data-studio-frame');
        let current = 0;

        function tick() {
          const next = (current + 1) % slides.length;
          slides[current].classList.remove('opacity-100');
          slides[current].classList.add('opacity-0');
          slides[next].classList.remove('opacity-0');
          slides[next].classList.add('opacity-100');
          current = next;
        }

        // Frame B starts half a cycle out of phase with frame A so
        // the two visible frames never crossfade at the same moment.
        const initialDelay = which === 'b' ? interval / 2 : 0;
        setTimeout(() => setInterval(tick, interval), initialDelay);
      });
    })();
  </script>
</BaseLayout>
