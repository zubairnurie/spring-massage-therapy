---
import { reader } from '../lib/reader';
import { buildJsonLdFromContent } from '../lib/seo';
import { type Locale, t, strings, localePath, pathWithoutLocale } from '../lib/i18n';

export interface Props {
  locale?: Locale;
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  locale = 'en',
  title,
  description,
  image,
  noindex = false,
} = Astro.props;

const s = strings(locale);

const site = await reader.singletons.site.read();
const siteUrl = (site?.siteUrl ?? Astro.site?.toString() ?? 'https://springmassagetherapy.ca').replace(/\/$/, '');

const path = Astro.url.pathname;
const canonical = siteUrl + path;
const cleanPath = pathWithoutLocale(path);

// Alternate language URLs for hreflang
const altEn = siteUrl + localePath(cleanPath, 'en');
const altFr = siteUrl + localePath(cleanPath, 'fr');

const defaultDescription = (locale === 'fr' ? site?.defaultDescriptionFr : site?.defaultDescriptionEn)
  ?? (locale === 'fr'
    ? 'Un havre de paix au cœur de Montréal. Massothérapie sur mesure par Zarah Bellamy.'
    : 'A peaceful retreat in the heart of Montréal. Tailored massage therapy by Zarah Bellamy.');

const finalTitle = title ?? (locale === 'fr'
  ? 'Spring Massage Therapy Montréal — Massothérapie par Zarah Bellamy'
  : 'Spring Massage Therapy — A peaceful retreat in Montréal');
const finalDescription = description ?? defaultDescription;

const socialImage = image ?? site?.socialImage ?? '/images/site/og-default.svg';
const absoluteSocialImage = socialImage ? new URL(socialImage, siteUrl).toString() : null;

const favicon = site?.favicon;
const jsonLd = await buildJsonLdFromContent(siteUrl);

import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- hreflang for bilingual SEO -->
    <link rel="alternate" hreflang="en" href={altEn} />
    <link rel="alternate" hreflang="fr-CA" href={altFr} />
    <link rel="alternate" hreflang="x-default" href={altEn} />

    <!-- Favicon -->
    {favicon ? (
      <link rel="icon" href={favicon} />
    ) : (
      <>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
      </>
    )}

    <!-- Open Graph -->
    <meta property="og:site_name" content="Spring Massage Therapy" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_CA' : 'en_CA'} />
    <meta property="og:locale:alternate" content={locale === 'fr' ? 'en_CA' : 'fr_CA'} />
    {absoluteSocialImage && (
      <>
        <meta property="og:image" content={absoluteSocialImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}

    <!-- Twitter card -->
    <meta name="twitter:card" content={absoluteSocialImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
    {absoluteSocialImage && <meta name="twitter:image" content={absoluteSocialImage} />}

    <!-- Structured data -->
    <script type="application/ld+json" set:html={jsonLd}></script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&family=Caveat:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <SiteHeader locale={locale} />
    <main class="flex-1">
      <slot />
    </main>
    <SiteFooter locale={locale} />

    <!-- Reveal-on-scroll: marks `data-reveal` elements with
         `data-reveal-shown` once they enter the viewport. CSS in
         global.css does the actual animation. No-op if
         IntersectionObserver isn't supported (elements stay visible
         via the prefers-reduced-motion fallback rule). -->
    <script is:inline>
      (function () {
        if (typeof IntersectionObserver === 'undefined') {
          document.querySelectorAll('[data-reveal]').forEach(function (el) {
            el.setAttribute('data-reveal-shown', '');
          });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.setAttribute('data-reveal-shown', '');
              io.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px 10% 0px', threshold: 0 });
        document.querySelectorAll('[data-reveal]').forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>
